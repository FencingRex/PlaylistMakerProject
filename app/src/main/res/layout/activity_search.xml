<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/search_btn"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/settingsScreen"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/marginMin"
        android:layout_marginBottom="@dimen/marginMin"
        android:layout_marginStart="@dimen/marginMin"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/searchBack"
            android:layout_width="@dimen/buttonSize"
            android:layout_height="@dimen/buttonSize"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/backButton"
            style="@style/settingsScreenIcon"
            app:icon="@drawable/ic_arrow_back_24"
            app:iconGravity="textStart"
            />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="@dimen/layoutWeight"
            android:paddingBottom="@dimen/paddingTextVertical"
            android:paddingStart="@dimen/paddingTextStart"
            android:paddingTop="@dimen/paddingTextTop"
            android:text="@string/search"
            style = "@style/settingsMenuText"
            android:textStyle="bold"
            android:fontFamily="@font/ys_display_medium"
            tools:ignore="RtlSymmetry"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/buttonSize"
        style="@style/settingsMenu">

        <EditText

            android:id="@+id/searchInputText"
            android:layout_width="match_parent"
            android:layout_height="@dimen/layoutHeight"
            style="@style/searchDisplayText"
            />

        <ImageView
            android:id="@+id/clearIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|end"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_clear_16"
            android:visibility="gone"
            app:tint="@color/yp_black"
             />

    </LinearLayout>

</LinearLayout>
